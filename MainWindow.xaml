<Window x:Class="ChatBotP2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot - ST10486804"
        Height="720" Width="980"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117">

	<Window.Resources>

		<Style x:Key="SendBtn" TargetType="Button">
			<Setter Property="Background" Value="#6E40C9"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="FontFamily" Value="Consolas"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="16,9">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="#8A5CF6"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="ClearBtn" TargetType="Button">
			<Setter Property="Background" Value="#21262D"/>
			<Setter Property="Foreground" Value="#8B949E"/>
			<Setter Property="BorderBrush" Value="#30363D"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="FontFamily" Value="Consolas"/>
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="14,9">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="#30363D"/>
								<Setter Property="Foreground" Value="#C9D1D9"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="ChipBtn" TargetType="Button">
			<Setter Property="Background" Value="SkyBlue"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="BorderBrush" Value="#6E40C9"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="FontFamily" Value="Segoe UI"/>
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Margin" Value="0,0,6,0"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20" Padding="12,5">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="#6E40C9"/>
								<Setter Property="Foreground" Value="White"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

	</Window.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- HEADER -->
		<Border Grid.Row="0" Background="#0D1117" Padding="0">
			<StackPanel>


				<Border Background="#0A0C16" Padding="16,12,16,8">
					<TextBlock FontFamily="Consolas" FontSize="12"
                               Foreground="SkyBlue"
                               HorizontalAlignment="Center"
                               LineHeight="17"
                               xml:space="preserve" Width="932">    _____      _                                        _ _                                                               ____        _    
  / ____|    | |                                      (_) |             /\                                              |  _ \      | |   
 | |    _   _| |__   ___ _ __ ___  ___  ___ _   _ _ __ _| |_ _   _     /  \__      ____ _ _ __ ___ _ __   ___  ___ ___  | |_) | ___ | |_  
 | |   | | | | '_ \ / _ \ '__/ __|/ _ \/ __| | | | '__| | __| | | |   / /\ \ \ /\ / / _` | '__/ _ \ '_ \ / _ \/ __/ __| |  _ &lt; / _ \| __| 
 | |___| |_| | |_) |  __/ |  \__ \  __/ (__| |_| | |  | | |_| |_| |  / ____ \ V  V / (_| | | |  __/ | | |  __/\__ \__ \ | |_) | (_) | |_  
  \_____\__, |_.__/ \___|_|  |___/\___|\___|\__,_|_|  |_|\__|\__, | /_/    \_\_/\_/ \__,_|_|  \___|_| |_|\___||___/___/ |____/ \___/ \__| 
         __/ |                                                __/ |                                                                       
        |___/                                                |___/</TextBlock>
				</Border>

				<!-- SUBTITLE BAR -->
				<Border Background="#161B22" Padding="20,10">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>

						<Border Grid.Column="0" Width="38" Height="38"
                                Background="SkyBlue" CornerRadius="8" Margin="0,0,12,0">
							<TextBlock Text="🛡" FontSize="18"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>

						<StackPanel Grid.Column="1" VerticalAlignment="Center">
							<TextBlock Text="CYBERSECURITY AWARENESS BOT" FontFamily="Consolas" FontSize="17"
                                       FontWeight="Bold" Foreground="SkyBlue"/>
							<TextBlock Text="I am here to help you stay safe online!"
                                       FontFamily="Segoe UI" FontSize="15" Foreground="#8B949E"/>
						</StackPanel>

						<Border Grid.Column="2" Background="#21262D" BorderBrush="BlueViolet"
                                BorderThickness="1" CornerRadius="20" Padding="12,5" VerticalAlignment="Center">
							<StackPanel Orientation="Horizontal">
								<TextBlock Text="Mood: " FontFamily="Consolas" FontSize="15"
                                           Foreground="#8B949E" VerticalAlignment="Center"/>
								<TextBlock x:Name="SentimentLabel" Text="Neutral 😐"
                                           FontFamily="Consolas" FontSize="15"
                                           Foreground="BlueViolet" VerticalAlignment="Center"/>
							</StackPanel>
						</Border>
					</Grid>
				</Border>

			</StackPanel>
		</Border>

		<!-- DIVIDER -->
		<Rectangle Grid.Row="1" Height="1" Fill="#6E40C9"/>

		<!-- CHAT AREA -->
		<Border Grid.Row="2" Margin="14,10,14,8"
                Background="#0D1117" BorderBrush="#2D1F4E" BorderThickness="1" CornerRadius="8">
			<ScrollViewer x:Name="ChatScroll"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="6" Margin="0,4,0,-4">
				<StackPanel x:Name="ChatPanel" Margin="6,4"/>
			</ScrollViewer>
		</Border>

		<!-- QUICK TOPIC CHIPS -->
		<Border Grid.Row="3" Margin="14,0,14,8"
                Background="#161B22" BorderBrush="#2D1F4E" BorderThickness="1"
                CornerRadius="8" Padding="10,7">
			<StackPanel Orientation="Horizontal">
				<TextBlock Text="Quick topics:" FontFamily="Segoe UI" FontSize="12"
                           Foreground="#8B949E" VerticalAlignment="Center" Margin="0,0,8,0"/>
				<Button Content="🔑 Password"      Style="{StaticResource ChipBtn}" Tag="password"      Click="TopicButton_Click"/>
				<Button Content="🎣 Phishing"      Style="{StaticResource ChipBtn}" Tag="phishing"      Click="TopicButton_Click"/>
				<Button Content="🌐 Safe Browsing" Style="{StaticResource ChipBtn}" Tag="safe browsing" Click="TopicButton_Click"/>
				<Button Content="🔒 Privacy"       Style="{StaticResource ChipBtn}" Tag="privacy"       Click="TopicButton_Click"/>
				<Button Content="⚠️ Scams"          Style="{StaticResource ChipBtn}" Tag="scam"          Click="TopicButton_Click"/>
				<Button Content="🦠 Malware"       Style="{StaticResource ChipBtn}" Tag="malware"       Click="TopicButton_Click"/>
				<Button Content="📋 My Tasks"      Style="{StaticResource ChipBtn}" Click="TaskButton_Click"/>
				<Button Content="🎮 Quiz"           Style="{StaticResource ChipBtn}" Click="QuizButton_Click"/>
			</StackPanel>
		</Border>

		<!-- INPUT ROW -->
		<Grid Grid.Row="4" Margin="14,0,14,10">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="277*"/>
				<ColumnDefinition Width="124*"/>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>
			<Border Grid.Column="0" Background="#161B22" BorderBrush="SkyBlue"
                    BorderThickness="1" CornerRadius="7" Margin="0,0,8,0" Grid.ColumnSpan="2">
				<TextBox x:Name="UserInput"
                         Background="Transparent" BorderThickness="0"
                         Foreground="#E6EDF3" CaretBrush="#C4B5FD"
                         FontFamily="Consolas" FontSize="13"
                         Padding="12,10" VerticalContentAlignment="Center"
                         KeyDown="UserInput_KeyDown"/>
			</Border>
			<Button Grid.Column="2" Content="Send ▶" Style="{StaticResource SendBtn}"
                    Height="42" Margin="0,0,8,0" Click="SendButton_Click"/>
			<Button Grid.Column="2" Content="Clear"  Style="{StaticResource ClearBtn}"
                    Height="42" Click="ClearButton_Click" Grid.ColumnSpan="2" Margin="87,0,0,0"/>
		</Grid>

		<!-- STATUS BAR -->
		<Border Grid.Row="5" Background="#161B22" BorderBrush="#30363D"
                BorderThickness="0,1,0,0" Padding="18,5">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>
				<TextBlock x:Name="StatusBar" Grid.Column="0"
                           Text="● Ready" FontFamily="Consolas"
                           FontSize="11" Foreground="Green"/>
				<TextBlock x:Name="ClockLabel" Grid.Column="1"
                           FontFamily="Consolas" FontSize="13" Foreground="#484F58"/>
			</Grid>
		</Border>

	</Grid>
</Window>






