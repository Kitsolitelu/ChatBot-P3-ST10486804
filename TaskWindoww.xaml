<Window x:Class="ChatBotP2.TaskWindoww"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot — Task Assistant"
        Height="680" Width="860"
        WindowStartupLocation="CenterOwner"
        Background="#0A0A12">

    <Window.Resources>

        <!-- Purple action button -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background"       Value="#6E40C9"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="FontFamily"       Value="Consolas"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="FontWeight"       Value="Bold"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="14,8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#8A5CF6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#5B21B6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sky blue complete button -->
        <Style x:Key="CompleteBtn" TargetType="Button">
            <Setter Property="Background"       Value="#0E86D4"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="FontFamily"       Value="Consolas"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#38BDF8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Red delete button -->
        <Style x:Key="DeleteBtn" TargetType="Button">
            <Setter Property="Background"       Value="#7F1D1D"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="FontFamily"       Value="Consolas"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EF4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Input field style -->
        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="Background"       Value="#161B22"/>
            <Setter Property="Foreground"       Value="#E6EDF3"/>
            <Setter Property="CaretBrush"       Value="#C4B5FD"/>
            <Setter Property="BorderBrush"      Value="#6E40C9"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="FontFamily"       Value="Consolas"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Padding"          Value="10,8"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header          -->
            <RowDefinition Height="Auto"/>   <!-- Add task form   -->
            <RowDefinition Height="*"/>      <!-- Task list       -->
            <RowDefinition Height="Auto"/>   <!-- Status bar      -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Padding="20,14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#0D0B1A" Offset="0"/>
                    <GradientStop Color="#161030" Offset="0.5"/>
                    <GradientStop Color="#0D0B1A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="42" Height="42"
                        CornerRadius="10" Margin="0,0,14,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#6E40C9" Offset="0"/>
                            <GradientStop Color="#38BDF8" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="📋" FontSize="20"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="TASK ASSISTANT"
                               FontFamily="Consolas" FontSize="16"
                               FontWeight="Bold">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#A78BFA" Offset="0"/>
                                <GradientStop Color="#38BDF8" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock Text="Manage your cybersecurity tasks"
                               FontFamily="Segoe UI" FontSize="11"
                               Foreground="#64748B" Margin="0,2,0,0"/>
                </StackPanel>

                <Button Grid.Column="2" Content="← Back to Chat"
                        Style="{StaticResource ActionBtn}"
                        Click="BackButton_Click"/>
            </Grid>
        </Border>

        <!-- ADD TASK FORM -->
        <Border Grid.Row="1"
                Background="#0F0B1E"
                BorderBrush="#6E40C9" BorderThickness="0,1,0,1"
                Padding="20,14">
            <StackPanel>
                <TextBlock Text="ADD NEW TASK"
                           FontFamily="Consolas" FontSize="11"
                           Foreground="#8B949E" Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Title -->
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Title" FontFamily="Consolas"
                                   FontSize="11" Foreground="#8B949E" Margin="0,0,0,4"/>
                        <TextBox x:Name="TitleInput"
                                 Style="{StaticResource InputField}"
                                 Height="38"/>
                    </StackPanel>

                    <!-- Description -->
                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                        <TextBlock Text="Description" FontFamily="Consolas"
                                   FontSize="11" Foreground="#8B949E" Margin="0,0,0,4"/>
                        <TextBox x:Name="DescInput"
                                 Style="{StaticResource InputField}"
                                 Height="38"/>
                    </StackPanel>

                    <!-- Reminder -->
                    <StackPanel Grid.Column="2" Margin="0,0,8,0">
                        <TextBlock Text="Reminder (optional)" FontFamily="Consolas"
                                   FontSize="11" Foreground="#8B949E" Margin="0,0,0,4"/>
                        <TextBox x:Name="ReminderInput"
                                 Style="{StaticResource InputField}"
                                 Height="38"/>
                    </StackPanel>

                    <!-- Add button -->
                    <Button Grid.Column="3" Content="+ Add Task"
                            Style="{StaticResource ActionBtn}"
                            VerticalAlignment="Bottom"
                            Height="38"
                            Click="AddTask_Click"/>
                </Grid>

                <!-- Hint text -->
                <TextBlock Text="Reminder examples:  'in 3 days'  |  'in 1 week'  |  '2026-07-15'"
                           FontFamily="Consolas" FontSize="10"
                           Foreground="#484F58" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- TASK LIST -->
        <Border Grid.Row="2" Margin="14,10,14,8"
                BorderThickness="1" CornerRadius="8">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#0A0A14" Offset="0"/>
                    <GradientStop Color="#0D0B18" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#6E40C9" Offset="0"/>
                    <GradientStop Color="#1E293B" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,10">
                <StackPanel x:Name="TaskListPanel"/>
            </ScrollViewer>
        </Border>

        <!-- STATUS BAR -->
        <Border Grid.Row="3" Padding="18,6"
                Background="#161B22"
                BorderBrush="#30363D" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusBar"
                           Grid.Column="0"
                           Text="● Ready — add a task above"
                           FontFamily="Consolas" FontSize="11"
                           Foreground="#4ADE80"/>
                <TextBlock x:Name="TaskCount"
                           Grid.Column="1"
                           FontFamily="Consolas" FontSize="11"
                           Foreground="#6E40C9"/>
            </Grid>
        </Border>
    </Grid>
</Window>

