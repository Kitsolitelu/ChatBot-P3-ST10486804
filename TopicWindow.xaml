<Window x:Class="ChatBotP2.TopicWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot — Topic"
        Height="620" Width="860"
        WindowStartupLocation="CenterOwner"
        Background="#0D1117">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#161B22"
                BorderBrush="#30363D" BorderThickness="0,0,0,1" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="← Back to Chat"
                        Click="BackButton_Click"
                        Background="BlueViolet" Foreground="White"
                        BorderBrush="#30363D" BorderThickness="1"
                        Padding="12,6" Cursor="Hand"
                        FontFamily="Consolas" FontSize="12"/>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="TopicTitle" FontFamily="Consolas" FontSize="16"
                               FontWeight="Bold" Foreground="SkyBlue" HorizontalAlignment="Center"/>
                    <TextBlock Text="Cybersecurity Topic" FontFamily="Consolas" FontSize="15"
                               Foreground="#8B949E" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="18,14">
            <StackPanel>

                <!-- Description card -->
                <Border Background="#161B22" BorderBrush="#30363D" BorderThickness="1"
                        CornerRadius="8" Padding="16,14" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock x:Name="TopicHeading" FontFamily="Consolas" FontSize="14"
                                   FontWeight="Bold" Foreground="SkyBlue" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TopicDescription" FontFamily="Consolas" FontSize="13"
                                   Foreground="#C9D1D9" TextWrapping="Wrap" LineHeight="22"/>
                    </StackPanel>
                </Border>

                <!-- Tips label -->
                <TextBlock Text="TIPS" FontFamily="Consolas" FontSize="11"
                           Foreground="#8B949E" Margin="0,0,0,8"/>

                <!-- Tips list -->
                <ItemsControl x:Name="TipsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#161B22" BorderBrush="SkyBlue"
                                    BorderThickness="3,0,0,0" Padding="14,10" Margin="0,0,0,8">
                                <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12"
                                           Foreground="#C9D1D9" TextWrapping="Wrap"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Example -->
                <Border Background="#0A1628" BorderBrush="SkyBlue" BorderThickness="1"
                        CornerRadius="8" Padding="14,12" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="EXAMPLE" FontFamily="Consolas" FontSize="10"
                                   Foreground="#8B949E" Margin="0,0,0,6"/>
                        <TextBlock x:Name="TopicExample" FontFamily="Consolas" FontSize="12"
                                   Foreground="#A8D8A8" TextWrapping="Wrap" LineHeight="20"/>
                    </StackPanel>
                </Border>

                <!-- Follow-up input -->
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#161B22" BorderBrush="#30363D"
                            BorderThickness="1" CornerRadius="7" Margin="0,0,8,0">
                        <TextBox x:Name="FollowUpInput" Background="Transparent"
                                 BorderThickness="0" Foreground="#E6EDF3"
                                 CaretBrush="#58A6FF" FontFamily="Consolas" FontSize="13"
                                 Padding="12,9" KeyDown="FollowUpInput_KeyDown"/>
                    </Border>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Ask ▶" Click="AskButton_Click"
                                Background="BlueViolet" Foreground="White" BorderThickness="0"
                                FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                Padding="16,9" Cursor="Hand" Margin="0,0,6,0"/>
                        <Button Content="Next tip ›" Click="AskButton_Click"
                                Background="BlueViolet" Foreground="White" BorderThickness="0"
                                FontFamily="Consolas" FontSize="12"
                                Padding="12,9" Cursor="Hand"
                                Tag="more" Width="87"/>
                    </StackPanel>
                </Grid>

                <!-- Follow-up response -->
                <Border x:Name="FollowUpBorder" Background="#161B22" BorderBrush="#30363D"
                        BorderThickness="1" CornerRadius="8" Padding="14,12"
                        Margin="0,10,0,0" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="[ BOT ]" FontFamily="Consolas" FontSize="11"
                                   FontWeight="Bold" Foreground="#58A6FF" Margin="0,0,0,6"/>
                        <TextBlock x:Name="FollowUpResponse" FontFamily="Consolas" FontSize="12"
                                   Foreground="#C9D1D9" TextWrapping="Wrap" LineHeight="20"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- STATUS -->
        <Border Grid.Row="2" Background="#161B22" BorderBrush="#30363D"
                BorderThickness="0,1,0,0" Padding="18,6">
            <TextBlock x:Name="StatusBar" FontFamily="Consolas" FontSize="11" Foreground="#4ADE80" TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Window>

