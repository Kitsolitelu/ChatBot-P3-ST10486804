<Window x:Class="ChatBotP2.QuizWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot — Cybersecurity Quiz"
        Height="620" Width="820"
        WindowStartupLocation="CenterOwner"
        Background="#0A0A12">

    <Window.Resources>

        <Style x:Key="AnswerBtn" TargetType="Button">
            <Setter Property="Background"      Value="#161B22"/>
            <Setter Property="Foreground"      Value="#C4B5FD"/>
            <Setter Property="BorderBrush"     Value="#6E40C9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="16,12">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"  Value="#2D1F4E"/>
                                <Setter Property="BorderBrush" Value="#A78BFA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background"      Value="#6E40C9"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="20,10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#8A5CF6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#2D1F4E"/>
                                <Setter Property="Foreground" Value="#484F58"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Padding="20,14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#0D0B1A" Offset="0"/>
                    <GradientStop Color="#161030" Offset="0.5"/>
                    <GradientStop Color="#0D0B1A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="42"
                        CornerRadius="10" Margin="0,0,14,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#6E40C9" Offset="0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="🎮" FontSize="20"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="CYBERSECURITY QUIZ"
                               FontFamily="Consolas" FontSize="16"
                               FontWeight="Bold">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#A78BFA" Offset="0"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock Text="Test your cybersecurity knowledge!"
                               FontFamily="Segoe UI" FontSize="11"
                               Foreground="#64748B" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Score badge -->
                <Border Grid.Column="2" Background="#21262D"
                        BorderBrush="#6E40C9" BorderThickness="1"
                        CornerRadius="20" Padding="14,6"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Score: " FontFamily="Consolas"
                                   FontSize="12" Foreground="#8B949E"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="ScoreLabel" Text="0 / 0"
                                   FontFamily="Consolas" FontSize="12"
                                   FontWeight="Bold" Foreground="#A78BFA"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- PROGRESS BAR -->
        <Border Grid.Row="1" Background="#161B22"
                BorderBrush="#30363D" BorderThickness="0,1,0,1"
                Padding="20,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Height="6" CornerRadius="3"
                        Background="#21262D" Margin="0,0,12,0">
                    <Border x:Name="ProgressFill" HorizontalAlignment="Left"
                            Height="6" CornerRadius="3" Width="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#6E40C9" Offset="0"/>
                                <GradientStop Color="#38BDF8" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Border>
                <TextBlock x:Name="ProgressLabel" Grid.Column="1"
                           FontFamily="Consolas" FontSize="11"
                           Foreground="#8B949E"/>
            </Grid>
        </Border>

        <!-- QUESTION AREA -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      Padding="20,16">
            <StackPanel>

                <!-- Question type badge -->
                <Border x:Name="QuestionTypeBadge"
                        Background="#2D1F4E" CornerRadius="4"
                        Padding="10,4" HorizontalAlignment="Left"
                        Margin="0,0,0,12">
                    <TextBlock x:Name="QuestionTypeLabel"
                               FontFamily="Consolas" FontSize="10"
                               Foreground="#A78BFA"/>
                </Border>

                <!-- Question text -->
                <TextBlock x:Name="QuestionText"
                           FontFamily="Consolas" FontSize="14"
                           Foreground="#E6EDF3"
                           TextWrapping="Wrap"
                           LineHeight="22"
                           Margin="0,0,0,20"/>

                <!-- Answer buttons -->
                <StackPanel x:Name="AnswerPanel"/>

                <!-- Feedback panel -->
                <Border x:Name="FeedbackPanel"
                        Visibility="Collapsed"
                        CornerRadius="8" Padding="16,12"
                        Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock x:Name="FeedbackTitle"
                                   FontFamily="Consolas" FontSize="14"
                                   FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="FeedbackText"
                                   FontFamily="Consolas" FontSize="12"
                                   Foreground="#C9D1D9"
                                   TextWrapping="Wrap" LineHeight="20"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- NAV BUTTONS -->
        <Border Grid.Row="3" Background="#0F0B1E"
                BorderBrush="#6E40C9" BorderThickness="0,1,0,0"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="← Back to Chat"
                        Style="{StaticResource NavBtn}"
                        Background="#21262D"
                        Click="BackButton_Click"/>
                <Button Grid.Column="2" x:Name="NextButton"
                        Content="Next Question ›"
                        Style="{StaticResource NavBtn}"
                        IsEnabled="False"
                        Click="NextButton_Click"/>
            </Grid>
        </Border>

        <!-- STATUS BAR -->
        <Border Grid.Row="4" Background="#161B22"
                BorderBrush="#30363D" BorderThickness="0,1,0,0"
                Padding="18,5">
            <TextBlock x:Name="StatusBar"
                       FontFamily="Consolas" FontSize="11"
                       Foreground="#4ADE80"
                       Text="● Select an answer to continue"/>
        </Border>
    </Grid>
</Window>
